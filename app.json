{
  "expo": {
    "name": "StreakFlow",
    "slug": "streakflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "streakflow",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rivro.streakflow.app"
    },
    "android": {
      "package": "com.rivro.streakflow.app"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "Heatmap",
              "label": "StreakFlow Heatmap",
              "minWidth": "160dp",
              "minHeight": "80dp",
              "targetWidth": "4x2",
              "targetHeight": "2x2",
              "description": "View your habit consistency"
            },
            {
              "name": "Stats",
              "label": "StreakFlow Stats",
              "minWidth": "80dp",
              "minHeight": "80dp",
              "targetWidth": "2x2",
              "targetHeight": "2x2",
              "description": "Your current streak and today's progress"
            },
            {
              "name": "Tasks",
              "label": "StreakFlow Tasks",
              "minWidth": "80dp",
              "minHeight": "80dp",
              "targetWidth": "2x2",
              "targetHeight": "3x2",
              "description": "See today's habits"
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3e9be9d0-df96-4322-9473-691abf7446db"
      }
    }
  }
}
