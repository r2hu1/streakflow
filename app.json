{
  "expo": {
    "name": "StreakFlow",
    "slug": "streakflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "streakflow",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#000000",
      "icon": "./assets/images/icon.png"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rivro.streakflow.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.rivro.streakflow.app"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "Heatmap",
              "label": "StreakFlow Heatmap",
              "minWidth": "160dp",
              "minHeight": "80dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "description": "View your habit consistency"
            },
            {
              "name": "Stats",
              "label": "StreakFlow Stats",
              "minWidth": "80dp",
              "minHeight": "80dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "description": "Your current streak and today's progress"
            },
            {
              "name": "Tasks",
              "label": "StreakFlow Tasks",
              "minWidth": "80dp",
              "minHeight": "80dp",
              "targetCellWidth": 2,
              "targetCellHeight": 3,
              "description": "See today's habits"
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3e9be9d0-df96-4322-9473-691abf7446db"
      }
    }
  }
}
